# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
.squad/rai/audit-trail.md merge=union
.squad/fact-checker/audit-trail.md merge=union

# schema_sync compares this generated file byte-for-byte; force LF so the check
# passes on Windows checkouts (autocrlf would otherwise convert it to CRLF).
schema/inference_metadata.schema.json text eol=lf

# Serialized ONNX protobufs must remain byte-identical across checkouts.
*.onnx binary
