/target
models/
*.onnx
# Fixture models are stored as git-friendly ONNX protobuf TextFormat
# (`*.onnx.textproto`), which is not matched by the `*.onnx` ignore above and is
# therefore tracked. The line below documents that intent explicitly.
!**/*.onnx.textproto
# Binary fixture models that must stay tracked (not converted to textproto).
!tests/fixtures/tiny-llm-scatter/model.onnx
!tests/fixtures/tiny-llm-sharedbuffer/model.onnx
!tests/fixtures/tiny-qwen35-mtp/model.onnx
!tests/fixtures/tiny-eagle3/model.onnx
!tests/fixtures/tiny-mtp-full/model.onnx
!tests/fixtures/tiny-mtp-full/mtp/model.onnx
!tests/fixtures/tiny-whisper/encoder.onnx
!tests/fixtures/tiny-whisper/decoder.onnx
!tests/fixtures/tiny-diffusion/denoiser.onnx
!tests/fixtures/tiny-diffusion/vae.onnx
!tests/fixtures/tiny-diffusion/denoiser_multi.onnx
!tests/fixtures/tiny-diffusion/denoiser_dualcond.onnx
!tests/fixtures/tiny-diffusion/denoiser_step.onnx
!tests/fixtures/tiny-dit-diffusion/denoiser.onnx
!tests/fixtures/tiny-masked-diffusion/lm.onnx
# `speculator-eagle3/model.onnx` is an 8-byte placeholder (never loaded as a
# model), kept as-is for model-directory resolution tests.
!crates/onnx-genai-ort/tests/fixtures/speculator-eagle3/model.onnx
# `qmoe_weight_offload/model.onnx` intentionally stays binary: its test exercises
# external-data (`weights.bin`) mmap weight-offload, which requires External
# weight refs that an inlined textproto cannot represent.
!crates/onnx-runtime-ep-cpu/tests/fixtures/qmoe_weight_offload/model.onnx
*.safetensors
.DS_Store

# Rust
# Existing Rust entries above: /target and Cargo.lock (left as-is).
**/*.rs.bk
*.pdb

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.so
.coverage
htmlcov/
.tox/

# Squad: ignore runtime state (logs, inbox, sessions)
# Note: .squad/casting/* is identity and MUST be committed to main, not ignored
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
